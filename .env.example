# ==============================================================================
# TestPilot AI — Environment Variables
# Copy this file to .env and fill in your values
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=TestPilot AI
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=change-me-to-a-very-long-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=testpilot
POSTGRES_PASSWORD=testpilot_secret
POSTGRES_DB=testpilot
DATABASE_URL=postgresql+asyncpg://testpilot:testpilot_secret@postgres:5432/testpilot

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/1

# ------------------------------------------------------------------------------
# Qdrant
# ------------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_secret
QDRANT_URL=http://qdrant:6333

# ------------------------------------------------------------------------------
# GitHub App — https://github.com/settings/apps
# Provide these when you create your GitHub App
# ------------------------------------------------------------------------------
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/secrets/github-private-key.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_NAME=testpilot-ai-app

# ------------------------------------------------------------------------------
# JWT Authentication
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=change-me-to-another-long-random-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ------------------------------------------------------------------------------
# LiteLLM / OpenAI
# Configure LiteLLM to use your preferred model provider
# If you have an OpenAI key, set OPENAI_API_KEY and set LITELLM_DEFAULT_MODEL=gpt-4.1
# Without a key, LiteLLM will use the LITELLM_DEFAULT_MODEL to route to local Ollama
# ------------------------------------------------------------------------------
OPENAI_API_KEY=sk-placeholder-replace-with-real-key
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_FALLBACK_MODEL=ollama/mistral
LITELLM_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_HOST=http://host.docker.internal:11434

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=

# Sentence Transformers (local embeddings fallback)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
USE_LOCAL_EMBEDDINGS=true

# ------------------------------------------------------------------------------
# Repository Storage
# Directory where repos are cloned
# ------------------------------------------------------------------------------
REPO_STORAGE_PATH=/tmp/repos
MAX_REPO_SIZE_MB=500

# ------------------------------------------------------------------------------
# Celery Flower
# ------------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=flower_secret

# ------------------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin_secret

# ------------------------------------------------------------------------------
# OpenTelemetry
# ------------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=testpilot-ai
OTEL_ENVIRONMENT=development

# ------------------------------------------------------------------------------
# Prometheus
# ------------------------------------------------------------------------------
PROMETHEUS_ENABLED=true

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ------------------------------------------------------------------------------
# Test Execution
# ------------------------------------------------------------------------------
TEST_EXECUTION_TIMEOUT_SECONDS=300
TEST_EXECUTION_MAX_PARALLEL=4
COVERAGE_THRESHOLD=80

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=TestPilot AI
