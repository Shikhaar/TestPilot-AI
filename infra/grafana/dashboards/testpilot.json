      },
      "id": 1,
      "title": "FastAPI HTTP Request Latency (seconds)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(testpilot_http_request_duration_seconds_sum[5m]) / rate(testpilot_http_request_duration_seconds_count[5m])",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Celery Task Queue Processing Time (seconds)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(testpilot_celery_task_duration_seconds_sum[5m])",
          "legendFormat": "{{task_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Active Celery Worker count",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "testpilot_celery_active_workers",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 4,
      "title": "Redis Queue Depth",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "testpilot_redis_queue_depth",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 5,
      "title": "LangGraph Agent Success Rate (%)",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(testpilot_agent_runs_total{status=\"success\"}[5m])) / sum(rate(testpilot_agent_runs_total[5m])) * 100",
          "refId": "A"
        }
      ]
    }
